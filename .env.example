# ===========================================
# Motico Solutions - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# Database
# ===========================================
# Local Docker PostgreSQL (development):
#   DATABASE_URL="postgresql://motico:motico_dev_pass@localhost:5433/motico_dev"
#   DIRECT_URL="postgresql://motico:motico_dev_pass@localhost:5433/motico_dev"
#
# Supabase (production/staging):
#   DATABASE_URL — Transaction pooler (IPv4, port 6543) for app runtime
#   DIRECT_URL  — Session pooler (IPv4, port 5432) for Prisma migrations/seed
#   Note: Direct connection (db.[ref].supabase.co) is IPv6-only

DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-1-[region].pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-1-[region].pooler.supabase.com:5432/postgres"

# Authentication
AUTH_SECRET="generate-with-openssl-rand-base64-32"
SESSION_EXPIRY_HOURS=720

# Environment
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# Email Configuration (SMTP)
# ===========================================
# For development, emails are logged to console
# For production, configure your SMTP provider

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
EMAIL_FROM="Motico Solutions <noreply@moticosolutions.com>"

# ===========================================
# Cloud Storage (Cloudinary)
# ===========================================
# Sign up at https://cloudinary.com (free tier available)

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ===========================================
# Optional: Analytics
# ===========================================

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ===========================================
# Optional: Payment Processing
# ===========================================

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
