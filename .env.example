# ===========================================
# Motico Solutions - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/motico_db"

# Authentication
AUTH_SECRET="generate-with-openssl-rand-base64-32"
SESSION_EXPIRY_HOURS=720

# Environment
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# Email Configuration (SMTP)
# ===========================================
# For development, emails are logged to console
# For production, configure your SMTP provider

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
EMAIL_FROM="Motico Solutions <noreply@moticosolutions.com>"

# ===========================================
# Cloud Storage (Cloudinary)
# ===========================================
# Sign up at https://cloudinary.com (free tier available)

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ===========================================
# Optional: Analytics
# ===========================================

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ===========================================
# Optional: Payment Processing
# ===========================================

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
